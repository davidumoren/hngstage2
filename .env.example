# Copy this file to .env and fill in your actual values
# Never commit .env to version control

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_password_here

# API
BACKEND_PORT=8000
API_URL=http://api:8000

# Frontend
FRONTEND_PORT=3000
PORT=3000

# Environment
APP_ENV=production